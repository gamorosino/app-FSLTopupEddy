#!/bin/bash
#PBS -l nodes=1:ppn=8,walltime=5:58:00
#PBS -N topup_eddy
#PBS -l vmem=16gb
#PBS -V

reslice=$(jq -r '.reslice' config.json)
if [[ ${reslice} == 'true' ]]; then
    [ -z "$FREESURFER_LICENSE" ] && echo "Please set FREESURFER_LICENSE in .bashrc" && exit 1
    echo "$FREESURFER_LICENSE" > license.txt

    time singularity exec -e \
        -B "$(pwd)/license.txt:/usr/local/freesurfer/license.txt" \
        docker://brainlife/freesurfer:6.0.0 \
        ./reslice.sh
fi

if [[ -s ./dwi/dwi.nii.gz && -s ./dwi/dwi.bvecs && -s ./dwi/dwi.bvals && -s ./mask/mask.nii.gz && -s ./eddy_quad/qc.pdf ]]; then
    echo "topup+eddy+qc already done"
else

    echo "DEBUG: run topup+eddy+qc"
    
    time singularity exec -e --nv \
        docker://gamorosino/fsl:6.0.7.22 \
        bash -lc '
    export FSLDIR=/usr/local/fsl
    source "$FSLDIR/etc/fslconf/fsl.sh"
    export PATH="$FSLDIR/bin:$FSLDIR/share/fsl/bin:/usr/bin:/bin"
    hash -r
    ./topup_eddy.sh
    ./eddy_qc.sh
    '
fi

echo "DEBUG: create regressor file"
time singularity exec -e \
    docker://brainlife/freesurfer-stats:1.2 \
    python3 ./createRegressorsTSV.py


if [[ -s ./dwi/dwi.nii.gz && -s ./dwi/dwi.bvecs && -s ./dwi/dwi.bvals && -s ./mask/mask.nii.gz ]]; then
    echo 0 > finished
else
    echo "output missing"
    echo 1 > finished
    exit 1
fi
